{
  "version": 4,
  "configurations": [
    {
      "name": "Jamma x64",
      "intelliSenseMode": "windows-msvc-x64",
      "cppStandard": "c++20",
      "defines": [
        "NOMINMAX",
        "WIN32_LEAN_AND_MEAN",
        "_CRT_SECURE_NO_WARNINGS",
        "__WINDOWS_DS__",
        "__WINDOWS_ASIO__",
        "__WINDOWS_MM__",
        "__STDC_LIB_EXT1__",
        "JAMMA_VST3_ENABLED",
        "JAMMA_VST2_ENABLED"
      ],
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/vcpkg_installed/x64-windows/include"
      ]
    }
  ]
}
